{
  "Routes": [
    {
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "${AUTH_SERVICE_HOST}", "Port": 8080 }
      ],
      "Key": "AuthService"
    },
    {
      "UpstreamPathTemplate": "/api/employees/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamPathTemplate": "/api/employees/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "${EMPLOYEE_SERVICE_HOST}", "Port": 8080 }
      ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "Key": "EmployeeService"
    },
    {
      "UpstreamPathTemplate": "/api/departments/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamPathTemplate": "/api/departments/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "${DEPARTMENT_SERVICE_HOST}", "Port": 8080 }
      ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "Key": "DepartmentService"
    },
    {
      "UpstreamPathTemplate": "/health",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "${EMPLOYEE_SERVICE_HOST}", "Port": 8080 }
      ],
      "Key": "HealthCheck"
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": ""
  }
}
