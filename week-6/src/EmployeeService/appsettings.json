{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EmployeeManagementDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Issuer": "EmployeeManagementAPI",
    "Audience": "EmployeeManagementClient",
    "ExpirationMinutes": 60
  },
  "AzureKeyVault": {
    "VaultUri": ""
  },
  "AzureBlobStorage": {
    "ContainerName": "employee-files"
  },
  "ApplicationInsights": {
    "InstrumentationKey": ""
  },
  "AzureFunctions": {
    "NotificationUrl": "",
    "FunctionKey": ""
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "HealthChecks": {
    "UI": {
      "HealthCheckDatabaseDetached": true
    }
  }
}
