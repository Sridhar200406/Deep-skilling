{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "AzureKeyVault": {
    "VaultUri": "https://<your-keyvault-name>.vault.azure.net/"
  },
  "AzureBlobStorage": {
    "ContainerName": "employee-files"
  },
  "JwtSettings": {
    "Issuer": "EmployeeManagementAPI",
    "Audience": "EmployeeManagementClient",
    "ExpirationMinutes": 60
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Notes": {
    "Info": "In Production, all secrets (ConnectionStrings, JwtSettings:SecretKey, AzureBlobStorage:ConnectionString) are loaded from Azure Key Vault. Do NOT hardcode secrets here."
  }
}
