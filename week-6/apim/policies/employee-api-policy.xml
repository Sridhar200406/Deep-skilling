<!--
  ═══════════════════════════════════════════════════════════════════════
  EMPLOYEE API POLICY — Applied to all /api/v1/employees operations
  
  All employee endpoints require a valid JWT token.
  Applies:
    - JWT validation
    - Rate limiting (100 calls/min per subscription key)
    - Role extraction from token
    - Request/response transformation
  ═══════════════════════════════════════════════════════════════════════
-->
<policies>
  <inbound>
    <base />

    <!-- ── JWT Validation ─────────────────────────────────────────── -->
    <validate-jwt
      header-name="Authorization"
      failed-validation-httpcode="401"
      failed-validation-error-message="Unauthorized. Valid JWT token required to access Employee APIs."
      require-expiration-time="true"
      require-scheme="Bearer"
      require-signed-tokens="true">

      <issuer-signing-keys>
        <key>{{jwt-secret-key}}</key>
      </issuer-signing-keys>
      <issuers>
        <issuer>EmployeeManagementAPI</issuer>
      </issuers>
      <audiences>
        <audience>EmployeeManagementClient</audience>
      </audiences>
      <output-token-variable-name="jwt" />
    </validate-jwt>

    <!-- ── Rate Limiting ──────────────────────────────────────────── -->
    <rate-limit-by-key
      calls="100"
      renewal-period="60"
      counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)"
      remaining-calls-variable-name="empRemainingCalls" />

    <!-- ── Extract role from JWT and forward to backend ──────────── -->
    <set-variable name="userRole"
      value="@{
        var jwt = (Jwt)context.Variables["jwt"];
        return jwt.Claims.GetValueOrDefault("role", "User");
      }" />

    <set-header name="X-User-Role" exists-action="override">
      <value>@((string)context.Variables["userRole"])</value>
    </set-header>
    <set-header name="X-User-Id" exists-action="override">
      <value>@{
        var jwt = (Jwt)context.Variables["jwt"];
        return jwt.Claims.GetValueOrDefault("sub", "");
      }</value>
    </set-header>
    <set-header name="X-Username" exists-action="override">
      <value>@{
        var jwt = (Jwt)context.Variables["jwt"];
        return jwt.Claims.GetValueOrDefault("unique_name", "");
      }</value>
    </set-header>

    <!-- ── Role-based access for destructive operations ──────────── -->
    <!-- DELETE requires Admin role -->
    <choose>
      <when condition="@(context.Request.Method == "DELETE" && (string)context.Variables["userRole"] != "Admin")">
        <return-response>
          <set-status code="403" reason="Forbidden" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{"success": false, "message": "Forbidden. Admin role required for delete operations.", "statusCode": 403}</set-body>
        </return-response>
      </when>
    </choose>

    <!-- ── Forward to Employee Service backend ───────────────────── -->
    <set-backend-service base-url="http://employee-service/api" />

    <!-- ── Rate limit response headers ───────────────────────────── -->
    <set-header name="X-Rate-Limit-Limit" exists-action="override">
      <value>100</value>
    </set-header>
    <set-header name="X-Rate-Limit-Remaining" exists-action="override">
      <value>@(context.Variables.GetValueOrDefault<int>("empRemainingCalls").ToString())</value>
    </set-header>

  </inbound>

  <backend>
    <base />
    <!-- Retry on transient server errors (not 4xx) -->
    <retry condition="@(context.Response.StatusCode >= 500)" count="3" interval="2" />
  </backend>

  <outbound>
    <base />
    <!-- Strip internal service headers from client responses -->
    <set-header name="X-User-Role" exists-action="delete" />
    <set-header name="X-User-Id" exists-action="delete" />
  </outbound>

  <on-error>
    <base />
  </on-error>
</policies>
