<!--
  ═══════════════════════════════════════════════════════════════════════
  RATE LIMITING POLICY
  
  Protects APIs from excessive traffic.
  Different limits per API group:
  
    Auth APIs:        10 calls / 60 seconds per IP  (prevents brute force)
    Employee APIs:   100 calls / 60 seconds per subscription key
    Department APIs: 200 calls / 60 seconds per subscription key
  
  Rate limiting is applied PER subscription key (or IP if no key).
  When limit exceeded, returns HTTP 429 Too Many Requests.
  ═══════════════════════════════════════════════════════════════════════
-->
<policies>
  <inbound>
    <base />

    <!-- ── Rate limit by subscription key ────────────────────────── -->
    <!-- 100 calls per 60 seconds per subscription key -->
    <rate-limit-by-key
      calls="100"
      renewal-period="60"
      counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)"
      increment-condition="@(true)"
      remaining-calls-variable-name="remainingCalls"
      retry-after-variable-name="retryAfter" />

    <!-- Add rate limit headers to response so clients know their limits -->
    <set-header name="X-Rate-Limit-Limit" exists-action="override">
      <value>100</value>
    </set-header>
    <set-header name="X-Rate-Limit-Remaining" exists-action="override">
      <value>@(context.Variables.GetValueOrDefault<int>("remainingCalls").ToString())</value>
    </set-header>

  </inbound>

  <backend>
    <base />
  </backend>

  <outbound>
    <base />
  </outbound>

  <on-error>
    <base />
    <choose>
      <when condition="@(context.Response.StatusCode == 429)">
        <set-header name="Content-Type" exists-action="override">
          <value>application/json</value>
        </set-header>
        <set-body>@{
          return new JObject(
            new JProperty("success", false),
            new JProperty("message", "Rate limit exceeded. Please slow down your requests."),
            new JProperty("statusCode", 429),
            new JProperty("retryAfter", context.Variables.GetValueOrDefault<int>("retryAfter")),
            new JProperty("timestamp", DateTime.UtcNow.ToString("O"))
          ).ToString();
        }</set-body>
      </when>
    </choose>
  </on-error>
</policies>
